#!/usr/bin/env bash
#
# run-experiment — QA harness for bny from a new user's perspective
#
# usage:
#   ./demos/run-experiment <name> <seed-description>
#
# creates demos/<name>/, inits bny, exercises brane, runs build.
# captures all output to demos/<name>/experiment.log
# errors are collected in demos/<name>/errors.log
#
# examples:
#   ./demos/run-experiment fizzbuzz-api "a REST API that serves fizzbuzz"
#   ./demos/run-experiment word-counter "a CLI that counts words, lines, and chars"
#

set -euo pipefail

NAME="${1:?usage: run-experiment <name> <seed-description>}"
DESC="${2:?usage: run-experiment <name> <seed-description>}"
BUNNY_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DEMO_DIR="$BUNNY_ROOT/demos/$NAME"
LOG="$DEMO_DIR/experiment.log"
ERRORS="$DEMO_DIR/errors.log"

export PATH="$BUNNY_ROOT/bin:$PATH"

if [ -d "$DEMO_DIR" ]; then
  echo "error: demos/$NAME already exists" >&2
  exit 1
fi

# -- helpers --

step() {
  local label="$1"
  shift
  echo "" >> "$LOG"
  echo "=== STEP: $label ===" >> "$LOG"
  echo "--- cmd: $* ---" >> "$LOG"
  echo "  [$label] $*"

  if "$@" >> "$LOG" 2>&1; then
    echo "--- exit: 0 ---" >> "$LOG"
  else
    local code=$?
    echo "--- exit: $code ---" >> "$LOG"
    echo "STEP=$label CMD=$* EXIT=$code" >> "$ERRORS"
    echo "  !! error (exit $code) — logged"
  fi
}

check() {
  local label="$1" condition="$2"
  if eval "$condition"; then
    echo "  [ok] $label" | tee -a "$LOG"
    return 0
  else
    echo "  [FAIL] $label" | tee -a "$LOG"
    echo "VALIDATION=$label" >> "$ERRORS"
    return 1
  fi
}

# -- setup --

echo "=== experiment: $NAME ==="
echo "=== description: $DESC ==="
echo ""

mkdir -p "$DEMO_DIR"
echo "experiment: $NAME" > "$LOG"
echo "description: $DESC" >> "$LOG"
echo "started: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$LOG"
touch "$ERRORS"

cd "$DEMO_DIR"

# -- phase 1: init --

step "bny-init"       bny init

# -- phase 2: seed --

echo "$DESC" > seed.md
step "digest-seed"    bny digest seed.md

# -- phase 3: exercise brane --

step "brane-storm"    bny brane storm "$DESC"
step "brane-tldr"     bny brane tldr
step "brane-ask"      bny brane ask "what are the key design decisions for this project?"

# -- phase 4: build --

step "build"          bny build --yes "$DESC"

# -- phase 5: check --

step "dev-test"       ./dev/test

# -- phase 6: validate outputs --

echo "" >> "$LOG"
echo "=== VALIDATION ===" >> "$LOG"
echo ""
echo "--- validation ---"

V_PASS=0
V_FAIL=0

run_check() {
  if check "$@"; then
    V_PASS=$((V_PASS + 1))
  else
    V_FAIL=$((V_FAIL + 1))
  fi
}

run_check "spec exists"           "ls specs/*/spec.md >/dev/null 2>&1"
run_check "plan exists"           "ls specs/*/plan.md >/dev/null 2>&1"
run_check "tasks exist"           "ls specs/*/tasks.md >/dev/null 2>&1"
run_check "current-feature set"   "[ -s bny/current-feature ]"
run_check "current-feature valid" "[ -d \"specs/\$(cat bny/current-feature 2>/dev/null | tr -d '\\n')\" ]"
run_check "src/ has .ts files"    "ls src/*.ts >/dev/null 2>&1 || ls src/**/*.ts >/dev/null 2>&1"
run_check "tests/ has test files" "ls tests/*.test.ts >/dev/null 2>&1"
run_check "worldview has content" "find bny/brane/worldview -name '*.md' -size +0 2>/dev/null | head -1 | grep -q ."
run_check "brane index exists"    "[ -s bny/brane/worldview/index.md ]"

echo "" >> "$LOG"
echo "validation: $V_PASS passed, $V_FAIL failed" >> "$LOG"

# -- summary --

echo "" >> "$LOG"
echo "finished: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$LOG"

# clean up nested .git — demos live inside parent repo
rm -rf "$DEMO_DIR/.git"

ERROR_COUNT=$(wc -l < "$ERRORS" | tr -d ' ')
echo ""
echo "=== done: $NAME ==="
echo "  log:         demos/$NAME/experiment.log"
echo "  errors:      $ERROR_COUNT"
echo "  validations: $V_PASS passed, $V_FAIL failed"
if [ "$ERROR_COUNT" -gt 0 ]; then
  echo ""
  cat "$ERRORS" | sed 's/^/  !! /'
fi
